# Skopiuj ten plik jako .env i uzupelnij przed docker-compose up

# Ollama chodzi natywnie na hoscie (Windows/WSL), nie w kontenerze,
# host.docker.internal dziala od razu z Docker Desktop
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# OpenRouter, fallback do miesiecznych insightow (darmowy tier)
# klucz z https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# sprawdz aktualna liste darmowych modeli na openrouter.ai/models (filtr :free)
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

DEBUG=true

# Nazwiska po przecinku do wykrywania przelewow rodzinnych/wlasnych
# (Odbiorca/Zleceniodawca w Millennium, Opis w Revolut), np. KOWALSKI
MONEY_MAP_FAMILY_SURNAMES=
